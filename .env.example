# Township runtime configuration
#
# Copy this file to .env, then set only the values your chosen provider needs.
# All secrets are server-side. Never use a VITE_ prefix for a secret.

# Scenario package under scenarios/. Both shipped examples work out of the box.
SCENARIO=nj11-2026

# bedrock | anthropic | openai | openrouter | ollama | lmstudio | mock
# Leave blank to auto-detect credentials; with no credentials Township uses mock.
LLM_PROVIDER=
LLM_MAX_CONCURRENT=10

# Deterministic zero-network provider. Set 0 for instant headless/CI runs.
MOCK_DELAY_S=0.05

# Direct Anthropic API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
# Experimental: enable only after your workload reports useful cache reads.
ANTHROPIC_CACHE_SYSTEM=0

# AWS Bedrock (bearer-token auth or the standard AWS credential chain)
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-2
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
# Township's changing per-agent system prompts make whole-block caching opt-in.
BEDROCK_CACHE_SYSTEM=0
BEDROCK_MAX_RETRIES=2

# OpenAI-compatible hosted providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Local OpenAI-compatible providers (install the `openai` extra)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model

# Optional voice features. OPENAI_API_KEY also powers /api/transcribe.
ELEVENLABS_API_KEY=

# Browser origins allowed for HTTP CORS and WebSocket handshakes.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:3000
# HTTP/WebSocket Host header allow-list (hostnames only, no scheme or port).
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional persistence overrides. Defaults are ./runs, ./data/state, and
# ./data/simulation_cache.json.
TOWNSHIP_RUNS_DIR=
TOWNSHIP_STATE_DIR=
TOWNSHIP_CACHE_PATH=

# Recorded zero-backend demos are committed per scenario at
# scenarios/<id>/demo/simulation_cache.json; they are not configured here.
