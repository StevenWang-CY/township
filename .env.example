# ───────────────────────────────────────────────────────────────────────────
# Township — environment configuration (copy to .env and fill in)
# All values below are SERVER-SIDE. Do NOT prefix any of these with VITE_ —
# the frontend never sees them; secrets stay on the backend.
# ───────────────────────────────────────────────────────────────────────────

# ── AWS Bedrock (the LLM) ──────────────────────────────────────────────────
# Bearer-token API key for Amazon Bedrock (preferred auth path). When unset,
# the standard AWS credential chain (SigV4 via boto3) is used as a fallback.
AWS_BEARER_TOKEN_BEDROCK=

# AWS region hosting the Bedrock cross-region inference profile.
# Default: us-east-2
AWS_REGION=us-east-2

# Override the default Bedrock model id. Optional.
# Default: us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Prompt caching on the persona system block (cuts repeated-call input cost
# ~85%). Set to 0 to disable. Optional — default on.
BEDROCK_CACHE_SYSTEM=1

# ── ElevenLabs (server-side text-to-speech proxy) ──────────────────────────
# Used by POST /api/tts. The browser POSTs {text, voice_id?} and the backend
# proxies ElevenLabs, so the client NEVER holds this key. When unset, /api/tts
# returns 503 {"error":"tts_unavailable"}.
ELEVENLABS_API_KEY=

# ── OpenAI Whisper (server-side speech-to-text) ────────────────────────────
# Used by POST /api/transcribe (model whisper-1). When unset, /api/transcribe
# returns 503 {"error":"transcription_unavailable"}.
OPENAI_API_KEY=

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins for the API.
# Default: http://localhost:5173,http://localhost:4173,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:3000

# ───────────────────────────────────────────────────────────────────────────
# NOTE: The simulation replay cache (data/simulation_cache.json) is NOT an env
# value — it is produced by running a full simulation (POST /api/simulation/start
# with no town), then replayed via POST /api/simulation/replay.
# ───────────────────────────────────────────────────────────────────────────
